<div class="nav-links">
    <a href="/">Home</a>
    {% if user.is_authenticated %}
        <a href="{% url 'retail-dashboard' %}" style="margin-left:20px;">Dashboard</a>
        <form method="POST" action="{% url 'logout' %}" style="display:inline; margin-left:20px;">
            {% csrf_token %}
            <button type="submit" style="background:transparent; color:#333; border:none; font-weight:500; cursor:pointer; padding:0; font-size:1rem;">Logout</button>
        </form>
    {% endif %}
</div>

